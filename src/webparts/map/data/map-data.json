  "contracts": {
    "SRS": {
      "fullName": "Stations, Rail & Systems",
      "description": "The SRS contract is the backbone of the YNSE programme, delivering five new subway stations, rail infrastructure, and all core systems integration. It spans the full alignment from Finch Station to the northern terminus at High Tech, covering tunnel-fit out, track installation, signalling, and station architecture.",
      "scope": "Full alignment — Finch to High Tech",
      "status": "Active",
      "municipalities": ["Toronto", "Vaughan", "Richmond Hill", "Markham"],
      "order": 0
    },
    "AT": {
      "fullName": "Advance Tunnel",
      "description": "The AT contract delivers the twin-bore TBM tunnels that form the underground right-of-way for the YNSE extension. Work includes launch and extraction shaft construction, tunnel boring, segment installation, and associated headwall structures at each emergency exit building location.",
      "scope": "Steeles to Portal — tunnel boring",
      "status": "Active",
      "municipalities": ["Toronto", "Vaughan"],
      "order": 1
    },
    "FEW": {
      "fullName": "Finch Early Works",
      "description": "The FEW contract covers enabling and preparatory works at the southern tie-in to the existing Finch Station. This includes siteworks, structural modifications, and mechanical/electrical fit-out of the tail track area to prepare for mainline construction.",
      "scope": "Finch Station — southern tie-in",
      "status": "Active",
      "municipalities": ["Toronto"],
      "order": 2
    }
  },
